{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "GroupId": "embedding-service",
    "MaxPollIntervalMs": 1800000
  },
  "Postgres": {
    "ConnectionString": "Host=postgres;Port=5432;Database=documentsearch;Username=documentsearch;Password=changeme"
  },
  "Qdrant": {
    "Endpoint": "qdrant",
    "Port": 6334,
    "CollectionName": "document_chunks",
    "VectorSize": 768
  },
  "Ollama": {
    "Endpoint": "http://ollama:11434",
    "Model": "nomic-embed-text",
    "EmbeddingBatchSize": 16,
    "EmbeddingRequestTimeoutSeconds": 120
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "Retry": {
    "MaxRetryCount": 5,
    "BackoffMinutes": [ 2, 5, 15, 30, 60 ]
  }
}
