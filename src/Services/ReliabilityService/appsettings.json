{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Kafka": {
    "BootstrapServers": "kafka:29092",
    "DlqTopicPartitions": 1,
    "DlqTopicReplicationFactor": 1
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "Retry": {
    "MaxRetryCount": 5,
    "BackoffMinutes": [ 2, 5, 15, 30, 60 ],
    "IdlePollSeconds": 5,
    "MaxWaitSeconds": 30,
    "PopBatchSize": 50
  }
}
