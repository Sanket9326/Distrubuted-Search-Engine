root = true

[*]
indent_style = space
indent_size = 4
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
csharp_style_namespace_declarations = file_scoped:error

# CA1040: Avoid empty interfaces.
# Infrastructure's abstraction interfaces (IKafkaProducer, IMinioStorage, IFileStorage, IClock)
# are intentionally empty placeholders until their implementations are scaffolded.
dotnet_diagnostic.CA1040.severity = none

[*.{json,yml,yaml}]
indent_size = 2
