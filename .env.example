# Postgres
POSTGRES_USER=documentsearch
POSTGRES_PASSWORD=changeme
POSTGRES_DB=documentsearch
POSTGRES_PORT=5432

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@documentsearch.com
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_PORT=5050

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_NAME=documents

# Kafka
KAFKA_PORT=9092

# Redis (scheduled retry queue)
REDIS_PORT=6379

# Upload Service
UPLOAD_SERVICE_PORT=8080

# Document Ingestion Service
DOCUMENT_INGESTION_SERVICE_PORT=8083

# Embedding Service
EMBEDDING_SERVICE_PORT=8084

# Reliability Service (retry/DLQ worker)
RELIABILITY_SERVICE_PORT=8086

# Search Service
SEARCH_SERVICE_PORT=8081

# Web UI
WEB_UI_PORT=4200

# Qdrant
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION_NAME=document_chunks

# Ollama
OLLAMA_PORT=11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Reranker (Text Embeddings Inference)
RERANKER_PORT=8082
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Gemini (LLM answer generation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Observability
CADVISOR_PORT=8085
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme
